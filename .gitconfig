[user]
	name = Jaden Stittsworth
	email = jstittsworth+irx@iralogix.com
[core]
	autocrlf = input
[rebase]
	autostash = true
[gpg]
	format = ssh
[gpg "ssh"]
	program = ssh-keygen
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[url "git@github.com:"]
	insteadOf = https://github.com/
