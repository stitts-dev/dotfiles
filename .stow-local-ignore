# GNU Stow ignore file
# Files and directories to ignore when creating symlinks

# Version control
\.git
\.gitignore
\.gitmodules

# Documentation (stow matches per path segment, so these block at any depth)
^README\.
^LICENSE\.
^CHANGELOG\.

# Backup and temporary files
.*~
\.bak$
\.tmp$
\.swp$
\.swo$

# Setup and configuration
setup\.sh
install\.sh
bootstrap\.sh

# macOS specific
\.DS_Store
\.AppleDouble
\.LSOverride

# Editor specific
\.vscode/
\.idea/

# Sensitive files (not symlinked)
\.npmrc

# Claude Code setup (consumed by script, not symlinked)
setup-claude\.sh
\.claude/settings\.json\.template